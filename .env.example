# Neon PostgreSQL connection string (required)
# Get yours at: https://console.neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@your-neon-host/your-database

# Test database — MUST be a separate Neon database or branch from DATABASE_URL.
# Integration tests truncate all tables between runs; never point this at a dev or prod database.
# Create a separate branch at: https://console.neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
TEST_DATABASE_URL=postgresql://user:password@your-neon-test-host/your-test-database

# Better Auth — required for session management
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here

# Base URL (server-side, used by Better Auth cookie domain)
BETTER_AUTH_URL=http://localhost:3000

# Base URL (client-side, used by authClient in React forms)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Payment gateway mode:
# - demo: internal simulation flow (/checkout/simulate) without Stripe API calls
# - stripe: real Stripe test-mode checkout + webhook flow
PAYMENT_MODE=demo

# Stripe API key (required only when PAYMENT_MODE=stripe)
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Stripe webhook signing secret for POST /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Resend API key for transactional emails (order confirmation + reminders)
RESEND_API_KEY=re_your_resend_api_key

# Sender email configured and verified in Resend
EMAIL_FROM=ingressos@77ticket.com

# Bearer token shared with Cloudflare Scheduled trigger for cron endpoint auth
CRON_SECRET=your-cron-secret
