{
  "name": "77ticket",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "lint": "eslint",
    "lint:architecture": "eslint src/app src/server",
    "ci:quality": "bun run lint && bun run lint:architecture && bun run test:unit && bun run test:regression && bun run build",
    "ci:integration": "bun run test:integration",
    "security:audit": "node scripts/ci/check-bun-audit-high.mjs",
    "test": "bun run test:unit && bun run test:regression && bun run test:integration",
    "test:unit": "vitest run --config vitest.config.ts --dir tests/unit",
    "test:regression": "vitest run --config vitest.config.ts --dir tests/regression",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest --config vitest.config.ts --dir tests/unit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "smoke": "tsx scripts/smoke/purchase-flow.ts && tsx scripts/smoke/checkin-flow.ts && tsx scripts/smoke/admin-flow.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.1",
    "gsap": "^3.14.2",
    "jsqr": "^1.4.0",
    "next": "16.2.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^4.8.0",
    "sonner": "^2.0.7",
    "stripe": "^18.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitejs/plugin-rsc": "^0.5.21",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "react-server-dom-webpack": "^19.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vinext": "^0.0.35",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "packageManager": "bun@1.3.3",
  "type": "module"
}
